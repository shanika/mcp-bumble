# Akahu Personal App credentials (https://my.akahu.nz/developers)
AKAHU_APP_TOKEN=app_token_xxxxx
AKAHU_USER_TOKEN=user_token_xxxxx

# SQLite database file path
DB_PATH=./bumble.db

# Nightly sync schedule (used by the Docker entrypoint / documented for cron)
SYNC_CRON_HOUR=2
SYNC_CRON_MINUTE=0
SYNC_TZ=Pacific/Auckland
